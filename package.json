{
	"name": "sos-grand-bazaar-recipies",
	"private": true,
	"license": "MIT",
	"version": "1.0.1",
	"type": "module",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"format": "biome format . --write",
		"create-data": "npx tsx ./create-recipes-data.ts && biome format ./src/assets --write",
		"electron:dev": "concurrently \"vite\" \"NODE_ENV=development electron .\"",
		"electron:build": "vite build && electron-builder",
		"electron:build:mac": "vite build && electron-builder --mac",
		"electron:build:win": "vite build && electron-builder --win",
		"electron:build:linux": "vite build && electron-builder --linux"
	},
	"build": {
		"appId": "com.kuukienator.sos-grand-bazaar-recipes",
		"productName": "SOS Grand Bazaar Recipes",
		"icon": "public/web-app-manifest-512x512.png",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**",
			"electron/**"
		],
		"mac": {
			"category": "public.app-category.games",
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				},
				{
					"target": "zip",
					"arch": [
						"x64",
						"arm64"
					]
				}
			]
		},
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			]
		},
		"linux": {
			"target": [
				{
					"target": "AppImage",
					"arch": [
						"x64"
					]
				}
			]
		},
		"publish": {
			"provider": "github"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^24.12.0",
		"@types/papaparse": "^5.5.2",
		"concurrently": "^9.0.0",
		"electron": "^41.0.0",
		"electron-builder": "^25.0.0",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"typescript": "~5.9.3",
		"vite": "^8.0.1"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"clsx": "^2.1.1",
		"papaparse": "^5.5.3",
		"tailwindcss": "^4.2.2"
	}
}
